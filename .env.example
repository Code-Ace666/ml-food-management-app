# Smart Food Waste Management System Environment Variables
DATABASE_URL=sqlite:///./food_waste.db
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
SECRET_KEY=dev_secret_key_change_in_production

# Webhook configuration for simulated NGO donations
NGO_WEBHOOK_URL=http://127.0.0.1:8000/api/donations/webhook-simulator
DONATION_THRESHOLD_KG=15.0

# Optional Premium Real Weather Integration
# Get a free key at https://openweathermap.org/
OPENWEATHERMAP_API_KEY=
DEFAULT_CITY=San_Francisco
